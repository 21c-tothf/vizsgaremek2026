{
  "info": {
    "name": "UsedCars API",
    "_postman_id": "a1f43a16-1e6e-4d69-a668-95dba357f8a7",
    "description": "End-to-end Postman collection for UsedCars backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Smoke — GET public listings",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/listings",
          "host": ["{{baseUrl}}"],
          "path": ["api", "listings"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Body is a JSON array', function () {",
              "  const data = pm.response.json();",
              "  pm.expect(Array.isArray(data)).to.be.true;",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Smoke — Login (seed admin)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('AuthResponse has token and userId', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.property('accessToken');",
              "  pm.expect(json.accessToken).to.be.a('string').and.to.have.lengthOf.at.least(10);",
              "  pm.expect(json).to.have.property('userId');",
              "  pm.expect(json.userId).to.be.a('number');",
              "});"
            ]
          }
        }
      ]
    },
