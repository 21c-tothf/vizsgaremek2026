    {
      "name": "5. Create Car (Seller)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{sellerToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"brand\": \"Toyota\",\n  \"model\": \"Corolla\",\n  \"year\": 2018,\n  \"mileage\": 87000,\n  \"fuelType\": \"Petrol\",\n  \"price\": 5600000,\n  \"description\": \"Well maintained\",\n  \"userId\": {{sellerUserId}}\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/cars",
          "host": ["{{baseUrl}}"],
          "path": ["api", "cars"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.environment.set('carId', json.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "6. Add Image to Car (Seller)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{sellerToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/cars/{{carId}}/images?imagePath={{imagePath}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "cars", "{{carId}}", "images"],
          "query": [
            { "key": "imagePath", "value": "{{imagePath}}" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "if (json.id) pm.environment.set('imageId', json.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "7. Send Message (Buyer -> Seller)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{buyerToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"carId\": {{carId}},\n  \"senderId\": {{buyerUserId}},\n  \"receiverId\": {{sellerUserId}},\n  \"message\": \"Hi, is this car still available?\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/messages",
          "host": ["{{baseUrl}}"],
          "path": ["api", "messages"]
        }
      },
